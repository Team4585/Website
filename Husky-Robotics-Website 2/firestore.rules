rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /events/{eventKey} {
      allow read: if signedIn();
      allow write: if signedIn();

      match /teams/{teamNumber} {
        allow read, write: if signedIn();
      }

      match /matches/{matchKey} {
        allow read, write: if signedIn();
      }

      match /apiCache/{cacheKey} {
        allow read, write: if signedIn();
      }

      match /scoutingEntries/{entryId} {
        allow read, create, update: if signedIn()
          && request.resource.data.eventKey == eventKey
          && request.resource.data.dataVersion is int;
        allow delete: if false;
      }
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
